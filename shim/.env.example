# Copy to `.env` next to ccusage-ship.py and fill in the real values.
# The installers create this file automatically; this is the documentation copy.

# --- Required ---
LANGFUSE_HOST=https://your-langfuse-instance.example.com
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE-ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE-ME
# Comma-separated. See https://ccusage.com for the supported source list.
# Trim down to what you actually use — there is no benefit to including
# sources you never run on this machine.
CCUSAGE_SOURCES=claude,codex,pi,copilot,gemini

# --- Optional ---
# How many days back each scheduled run (re-)ships. Upserts in Langfuse, so a
# wider window just backfills gaps without duplicating — bump it if the machine
# is sometimes offline for a while. Default is 14.
CCUSAGE_SINCE_DAYS=14

# Trace granularity: "session" (default) groups by ccusage session, so you can
# see which session/project drove the spend; "daily" is one trace per day.
# CCUSAGE_GRANULARITY=session

# Override the hostname used as the trace grouping key. Default is
# socket.gethostname(); set this when the OS name is unhelpful, or to
# distinguish WSL2 from its host Windows (see README "Windows + WSL2").
# TOKEN_USAGE_HOSTNAME=my-desktop

# If set to "1", print the batch instead of POSTing. Use for first-time
# validation, then unset.
# TOKEN_USAGE_DRY_RUN=1
